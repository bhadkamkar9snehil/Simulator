iv class="softCard full"><h3>Connection Result</h3><pre id="connResult" class="statusBox">No connection action yet.</pre></div></div></div>
  <div id="map" class="subpanel"><div class="grid"><div class="softCard third"><h2>Each API Own Table or Excel</h2><label>API Endpoint</label><select id="apiEndpoint"></select><label>Data source</label><select id="apiSource"><option value="mssql">MSSQL table</option><option value="excel">Excel / CSV file</option><option value="sqlite">API Studio internal datastore</option></select><label>Database</label><select id="mapDatabase"></select><label>Table</label><select id="mapTable"></select><label>Excel / CSV File</label><select id="mapExcel"></select><label>Sheet</label><input id="mapSheet" value="active"><button class="btn primary" onclick="saveMapping()">Save Mapping for API</button></div><div class="softCard twoThird"><h2>Saved API Source Mappings</h2><div class="tableWrap"><table id="mappingTable"></table></div></div></div></div>
  <div id="launcher" class="subpanel"><div class="grid"><div class="softCard full"><div class="row" style="justify-content:space-between"><div><h2>Application Control + Port Selection</h2><p class="muted">Services run hidden in background. Required packages install automatically from bundled wheels when missing.</p></div><div id="launcherInlineStatus" class="row"></div></div><div class="controlGrid"><div class="controlBlock"><h3>Port Selection</h3><label>Industrial web UI</label><input id="launcherIndustrialPort" value="8000"><label>API Studio</label><input id="launcherApiPort" value="5050"><label>Top-tab portal</label><input id="launcherPortalPort" value="8001"><label>OPC UA server</label><input id="launcherOpcuaPort" value="4840"><label>MQTT broker/client</label><input id="launcherMqttPort" value="1883"></div><div class="controlBlock"><h3>Actions</h3><div class="row"><button class="btn primary" onclick="launcherStart()">Start Services Hidden</button><button class="btn bad" onclick="launcherStopAll()">Stop All</button></div><div class="row" style="margin-top:8px"><button class="btn" onclick="launcherSave()">Save Ports</button><button class="btn" onclick="loadLauncher()">Refresh Status</button></div><div class="row" style="margin-top:8px"><button class="btn blue" onclick="launcherOpenApp()">Open App Window</button><a id="launcherOpenPortal" class="btn" href="#">Open Portal</a><a id="launcherOpenApi" class="btn" href="#" target="_blank">Open API Studio</a></div></div><div class="controlBlock"><h3>Service Status + URLs</h3><pre id="launcherUrls" class="statusBox" style="max-height:230px">Loading...</pre></div></div></div><div class="softCard half"><h3>Launcher Result</h3><pre id="launcherResult" class="statusBox">No launcher action yet.</pre></div><div class="softCard half"><h3>Launcher Log</h3><pre id="launcherLog" class="statusBox">Loading launcher log...</pre></div></div></div>
 </div>
</div></section>
</main></div>
<script>
const INDUSTRIAL='http://127.0.0.1:__INDUSTRIAL_PORT__';
const API='http://127.0.0.1:__API_STUDIO_PORT__';
let files=[], generators=[], spec=null, endpoints=[], mappings=[];
function qs(id){return document.getElementById(id)}
function showMain(id,btn){document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));qs(id).classList.add('active');document.querySelectorAll('.appTabs button').forEach(x=>x.classList.remove('active'));btn.classList.add('active')}
function showSub(id,btn){document.querySelectorAll('.subpanel').forEach(x=>x.classList.remove('active'));qs(id).classList.add('active');document.querySelectorAll('.apiMenu button').forEach(x=>x.classList.remove('active'));btn.classList.add('active')}
async function getJson(url){const r=await fetch(url); return await r.json()}
async function postJson(url,body){const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body||{})}); return await r.json()}
function pretty(x){return JSON.stringify(x,null,2)}
function safe(s){return String(s??'').replace(/[&<>]/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[ch]))}
async function loadStatus(){try{const s=await getJson('/suite/status'); topStatus.innerHTML='<span class="pill">Portal OK</span><span class="pill">Industrial '+(s.industrial.ok?'OK':'OFF')+'</span><span class="pill">API Studio '+(s.api_studio.ok?'OK':'OFF')+'</span>'; const st=await getJson(INDUSTRIAL+'/api/status'); runResult.textContent=pretty(st); }catch(e){topStatus.innerHTML='<span class="pill">Status loading</span>'}}
async function loadGenerators(){try{const data=await getJson(INDUSTRIAL+'/api/generators'); generators=data.generators||[]; genDomain.innerHTML=generators.map(g=>`<option value="${g.domain_id}">${safe(g.display_name)}</option>`).join(''); await loadSpec()}catch(e){genResult.textContent='Could not load generators: '+e.message}}
async function loadSpec(){try{const id=genDomain.value;if(!id)return; spec=await getJson(INDUSTRIAL+'/api/generators/'+id+'/spec'); genScenario.innerHTML=(spec.scenarios||[]).map(s=>`<option value="${s.id}">${safe(s.label)}</option>`).join(''); if(spec.default_output_filename) genOutput.value=spec.default_output_filename; genParams.innerHTML=(spec.parameters||[]).map(p=>`<label>${safe(p.label||p.name)}${p.unit?' ('+safe(p.unit)+')':''}</label>${paramInput(p)}`).join('')}catch(e){genResult.textContent='Could not load spec: '+e.message}}
function paramInput(p){const v=p.default??''; if(p.type==='select' && p.options){return `<select data-param="${p.name}">${p.options.map(o=>`<option value="${o}" ${String(o)===String(v)?'selected':''}>${safe(o)}</option>`).join('')}</select>`} return `<input data-param="${p.name}" value="${safe(v)}" type="${p.type==='number'?'number':'text'}">`}
async function generateData(){try{const params={};document.querySelectorAll('[data-param]').forEach(el=>params[el.dataset.param]=el.value); const body={scenario:genScenario.value,output_filename:genOutput.value,parameters:params,load_into_replay:true}; const res=await postJson(INDUSTRIAL+'/api/generators/'+genDomain.value+'/generate',body); genResult.textContent=pretty(res); await loadFiles()}catch(e){genResult.textContent='Generate failed: '+e.message}}
async function uploadSelectedFile(){const f=uploadFile.files[0]; if(!f){alert('Choose a CSV or XLSX file first.');return} const fd=new FormData(); fd.append('file',f); const r=await fetch(INDUSTRIAL+'/api/csv/upload',{method:'POST',body:fd}); const j=await r.json(); planPreview.textContent=pretty(j); await loadFiles()}
async function loadFiles(){try{const data=await getJson(INDUSTRIAL+'/api/csv/files'); files=data.files||[]; fileSummary.textContent=`${files.length} files loaded`; renderFiles(); refreshExcelFiles()}catch(e){fileSummary.textContent='Could not load files: '+e.message}}
function fileKey(f){return (f.source+'__'+f.filename).replace(/[^A-Za-z0-9_]/g,'_')}
function renderFiles(){const rows=files.map(f=>`<tr><td>${safe(f.filename)}</td><td>${safe(f.source)}</td><td>${f.row_count}</td><td>${f.column_count}</td><td><label><input type="checkbox" class="filePick" data-key="${fileKey(f)}"> use</label></td><td><label><input type="checkbox" class="shared" data-key="${fileKey(f)}"> Shared</label></td><td><label><input type="checkbox" class="opcua" data-key="${fileKey(f)}"> OPC UA</label></td><td><label><input type="checkbox" class="mqtt" data-key="${fileKey(f)}"> MQTT</label></td><td><button class="btn small" onclick="previewFile('${f.source}','${f.filename.replace(/'/g,"\\'")}')">Preview</button></td></tr>`).join(''); const head='<tr><th>File</th><th>Source</th><th>Rows</th><th>Cols</th><th>Pick</th><th>Shared</th><th>OPC UA</th><th>MQTT</th><th>Preview</th></tr>'; filesTable.innerHTML=head+rows; assignTable.innerHTML=head+rows; updatePlanPreview()}
async function previewFile(source,filename){const data=await getJson(INDUSTRIAL+`/api/csv/files/${encodeURIComponent(filename)}/metadata?source=${source}`); planPreview.textContent=pretty(data)}
function assignCheckedFiles(){const mode=quickProtocol.value; document.querySelectorAll('.filePick:checked').forEach(p=>{const key=p.dataset.key; ['shared','opcua','mqtt'].forEach(cls=>document.querySelectorAll('.'+cls+'[data-key="'+key+'"]').forEach(c=>c.checked=(cls===mode)))}); updatePlanPreview()}
document.addEventListener('change',e=>{if(e.target.matches('.shared,.opcua,.mqtt,.filePick')) updatePlanPreview()})
function selectedFiles(cls){const keys=[...document.querySelectorAll('.'+cls+':checked')].map(x=>x.dataset.key); return files.filter(f=>keys.includes(fileKey(f))).map(f=>({filename:f.filename,source:f.source}))}
function updatePlanPreview(){const plan={shared:selectedFiles('shared'),opcua:selectedFiles('opcua'),mqtt:selectedFiles('mqtt')}; planPreview.textContent=pretty(plan); return plan}
function replayConfig(protocol){const p=updatePlanPreview(); return {protocol:protocol,files:p.shared,opcua_files:p.opcua,mqtt_files:p.mqtt,frequency_hz:parseFloat(frequency.value||'1'),loop_mode:loopMode.value,timestamp_mode:timestampMode.value,start_row:parseInt(startRow.value||'0'),max_rows:maxRows.value?parseInt(maxRows.value):null,namespace_uri:namespaceUri.value,root_folder:rootFolder.value,node_id_prefix:nodePrefix.value,mqtt_host:mqttHost.value,mqtt_port:parseInt(mqttPort.value||'1883'),mqtt_topic_prefix:mqttTopic.value,mqtt_client_id:'industrial-tag-simulator',mqtt_qos:0,mqtt_retain:false,publish_individual_tags:pubIndividual.checked,publish_aggregate:pubAggregate.checked,tag_selections:[]}}
async function startRun(protocol){try{let cfg=replayConfig(protocol); if(protocol==='opcua' && !cfg.files.length && !cfg.opcua_files.length) throw new Error('Select at least one shared or OPC UA file.'); if(protocol==='mqtt' && !cfg.files.length && !cfg.mqtt_files.length) throw new Error('Select at least one shared or MQTT file.'); if(protocol==='both' && !cfg.files.length && (!cfg.opcua_files.length || !cfg.mqtt_files.length)) { if(!cfg.files.length) throw new Error('For Both, select shared file(s), or select OPC UA file(s) and MQTT file(s).') } const conf=await postJson(INDUSTRIAL+'/api/replay/configure-files',cfg); const start=await postJson(INDUSTRIAL+'/api/replay/start-'+protocol,{}); runResult.textContent=pretty({configured:conf,start:start})}catch(e){runResult.textContent='Start failed: '+e.message}}
async function stopRun(protocol){try{const res=await postJson(INDUSTRIAL+'/api/replay/stop-'+protocol,{}); runResult.textContent=pretty(res)}catch(e){runResult.textContent='Stop failed: '+e.message}}
async function loadLive(){try{const d=await getJson(INDUSTRIAL+'/api/replay/current-values'); const rows=(d.values||[]).map(v=>`<tr><td>${safe(v.tag_name)}</td><td>${safe(v.value)}</td><td>${safe(v.data_type)}</td><td>${safe(v.node_id)}</td><td>${safe(v.last_updated)}</td></tr>`).join(''); liveTable.innerHTML='<tr><th>Tag</th><th>Value</th><th>Type</th><th>Node ID</th><th>Updated</th></tr>'+rows}catch(e){}}
function dbCfg(){return {server:server.value,port:dbPort.value,database:database.value,auth:auth.value,username:username.value,password:password.value,table:table.value,encrypt:encrypt.checked,trust_server_certificate:trust.checked}}
function showConn(x){connResult.textContent=pretty(x)}
async function testMssql(){showConn(await postJson('/mssql/test',dbCfg()))}
async function writeCurrent(){showConn(await postJson('/mssql/write-current',dbCfg()))}
async function listDatabases(){const res=await postJson('/mssql/list-databases',dbCfg()); showConn(res); if(res.databases){database.innerHTML=res.databases.map(x=>`<option value="${safe(x)}">${safe(x)}</option>`).join(''); mapDatabase.innerHTML=database.innerHTML}}
async function listTables(){const res=await postJson('/mssql/list-tables',dbCfg()); showConn(res); if(res.tables){table.innerHTML=res.tables.map(x=>`<option value="${safe(x)}">${safe(x)}</option>`).join(''); mapTable.innerHTML=table.innerHTML}}
async function refreshExcelFiles(){const opts=files.map(f=>`<option value="${safe(f.source+'|'+f.filename)}">${safe(f.source+' / '+f.filename)}</option>`).join(''); excelFile.innerHTML=opts; mapExcel.innerHTML=opts}
async function loadApiEndpoints(){try{const data=await getJson(API+'/api/studio/endpoints'); endpoints=data.data||[]; apiEndpoint.innerHTML=endpoints.map(e=>`<option value="${e.id}">${safe(e.method+' '+e.path+' - '+e.name)}</option>`).join(''); await loadMappings()}catch(e){apiResult.textContent='Could not load API Studio endpoints: '+e.message}}
async function loadMappings(){const res=await getJson('/api-mappings'); mappings=res.mappings||[]; renderMappings()}
async function saveMapping(){const ep=endpoints.find(e=>e.id===apiEndpoint.value)||{}; const m={endpoint_id:apiEndpoint.value,endpoint_name:ep.name||'',method:ep.method||'',path:ep.path||'',source_type:apiSource.value,database:mapDatabase.value,table:mapTable.value,excel:mapExcel.value,sheet:mapSheet.value,updated_at:new Date().toISOString()}; const res=await postJson('/api-mappings/save',m); mappings=res.mappings||[]; renderMappings()}
function renderMappings(){mappingTable.innerHTML='<tr><th>API</th><th>Method</th><th>Path</th><th>Source</th><th>DB/Table</th><th>Excel</th><th>Sheet</th></tr>'+mappings.map(m=>`<tr><td>${safe(m.endpoint_name)}</td><td>${safe(m.method)}</td><td>${safe(m.path)}</td><td>${safe(m.source_type)}</td><td>${safe((m.database||'')+' / '+(m.table||''))}</td><td>${safe(m.excel||'')}</td><td>${safe(m.sheet||'')}</td></tr>`).join('')}
async function quickGet(path){if(path.includes('stream')){window.open(API+path,'_blank');return} const res=await getJson(API+path); apiResult.textContent=pretty(res)}
async function quickPost(path,bodyText){let body={}; try{body=JSON.parse(bodyText)}catch(e){apiResult.textContent='Invalid JSON: '+e.message; return} const res=await postJson(API+path,body); apiResult.textContent=pretty(res)}
function launcherPorts(){return {industrial_web_port:launcherIndustrialPort.value.trim(),api_studio_port:launcherApiPort.value.trim(),portal_port:launcherPortalPort.value.trim(),opcua_port:launcherOpcuaPort.value.trim(),mqtt_broker_port:launcherMqttPort.value.trim()}}
function launcherStatusBadges(status){return Object.entries(status||{}).map(([k,v])=>`<span class="pill">${safe(k)}: <strong style="margin-left:6px;color:${v?'#14804a':'#c53030'}">${v?'ON':'OFF'}</strong></span>`).join('')}
function launcherUrlsText(data){const u=data.urls||{}; return `Portal:               ${u.portal||''}\nIndustrial simulator: ${u.industrial||''}\nAPI Studio:           ${u.api_studio||''}\nOPC UA endpoint:      ${u.opcua||''}\nMQTT broker/client:   ${u.mqtt||''}` }
function applyLauncher(data){const p=data.ports||{}; launcherIndustrialPort.value=p.industrial_web_port||launcherIndustrialPort.value; launcherApiPort.value=p.api_studio_port||launcherApiPort.value; launcherPortalPort.value=p.portal_port||launcherPortalPort.value; launcherOpcuaPort.value=p.opcua_port||launcherOpcuaPort.value; launcherMqttPort.value=p.mqtt_broker_port||launcherMqttPort.value; launcherInlineStatus.innerHTML=launcherStatusBadges(data.status||{}); launcherUrls.textContent=launcherUrlsText(data); launcherLog.textContent=data.log||'No launcher log yet.'; if(data.urls){launcherOpenPortal.href=data.urls.portal||'#'; launcherOpenApi.href=data.urls.api_studio||'#';}}
async function loadLauncher(){try{const data=await getJson('/launcher/config'); applyLauncher(data)}catch(e){launcherResult.textContent='Could not load launcher settings: '+e.message}}
async function launcherSave(){try{const res=await postJson('/launcher/save',{ports:launcherPorts()}); launcherResult.textContent=pretty(res); applyLauncher(res)}catch(e){launcherResult.textContent='Save failed: '+e.message}}
async function launcherStart(){try{const res=await postJson('/launcher/start',{ports:launcherPorts(),include_portal:false}); launcherResult.textContent=pretty(res); applyLauncher(res); setTimeout(loadStatus,1200)}catch(e){launcherResult.textContent='Start failed: '+e.message}}
async function launcherOpenApp(){try{const res=await postJson('/launcher/open-app',{ports:launcherPorts()}); launcherResult.textContent=pretty(res); applyLauncher(res)}catch(e){launcherResult.textContent='Open app failed: '+e.message}}
async function launcherStopAll(){if(!confirm('Stop all services?')) return; try{const res=await postJson('/launcher/stop',{ports:launcherPorts(),include_portal:false}); launcherResult.textContent=pretty(res); applyLauncher(res); setTimeout(loadStatus,1200)}catch(e){launcherResult.textContent='Stop failed: '+e.message}}
loadLauncher(); loadStatus(); loadGenerators(); loadFiles(); loadApiEndpoints(); setInterval(loadStatus,4000); setInterval(loadLive,1000); setInterval(loadLauncher,5000);
</script>
</body></html>'''
    replacements = {
        "__LAN_IP__": local_ip(),
        "__PORT__": str(PORT),
        "__INDUSTRIAL_PORT__": str(INDUSTRIAL_PORT),
        "__API_STUDIO_PORT__": str(API_STUDIO_PORT),
        "__OPCUA_PORT__": str(OPCUA_PORT),
        "__MQTT_BROKER_PORT__": str(MQTT_BROKER_PORT),
    }
    for key, val in replacements.items():
        template = template.replace(key, val)
    return template

class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt: str, *args) -> None:
        return

    def do_OPTIONS(self) -> None:
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self) -> None:
        path = urlparse(self.path).path
        if path in ("/", "/index.html"):
            return html_response(self, page())
        if path == "/suite/status":
            return json_response(self, 200, {
                "portal": {"ok": True, "port": PORT},
                "industrial": get_service(f"http://127.0.0.1:{INDUSTRIAL_PORT}/api/health"),
                "api_studio": get_service(f"http://127.0.0.1:{API_STUDIO_PORT}/api/studio/health"),
            })
        if path == "/launcher/config":
            return json_response(self, 200, suite_status_payload(suite_load_ports()))
        if path == "/connections":
            return json_response(self, 200, {"connections": read_store(CONNECTIONS_JSON, {})})
        if path == "/api-mappings":
            return json_response(self, 200, {"mappings": read_store(MAPPINGS_JSON, [])})
        return json_response(self, 404, {"ok": False, "error": "Not found"})

    def do_POST(self) -> None:
        path = urlparse(self.path).path
        try:
            body = read_json(self)
            if path == "/launcher/save":
                ports = body.get("ports") or suite_load_ports()
                errors = suite_validate_ports(ports)
                if errors:
                    payload = suite_status_payload(suite_load_ports())
                    payload.update({"ok": False, "message": "; ".join(errors)})
                    return json_response(self, 200, payload)
                suite_save_ports(ports)
                payload = suite_status_payload(ports)
                payload.update({"ok": True, "message": "Ports saved."})
                return json_response(self, 200, payload)
            if path == "/launcher/start":
                ports = body.get("ports") or suite_load_ports()
                include_portal = bool(body.get("include_portal", False))
                ok, msg = suite_start_services(ports, include_portal=include_portal, open_browser_flag=False)
                payload = suite_status_payload(ports)
                payload.update({"ok": ok, "message": msg})
                return json_response(self, 200, payload)
            if path == "/launcher/open-app":
                ports = body.get("ports") or suite_load_ports()
                suite_save_ports(ports)
                ok = suite_open_app_window(f"http://localhost:{ports['portal_port']}")
                payload = suite_status_payload(ports)
                payload.update({"ok": True, "message": "Application window requested." if ok else "Default browser opened because Edge/Chrome app mode was not found."})
                return json_response(self, 200, payload)
            if path == "/launcher/stop":
                ports = body.get("ports") or suite_load_ports()
                include_portal = bool(body.get("include_portal", False))
                if include_portal:
                    helper_py = str(SUITE_VENV_PYW if SUITE_VENV_PYW.exists() else SUITE_VENV_PY)
                    subprocess.Popen([helper_py, str(ROOT / "stop_hidden.py")], cwd=str(ROOT), creationflags=CREATE_NO_WINDOW)
                    payload = suite_status_payload(ports)
                    payload.update({"ok": True, "message": "Full stop requested. Portal may close."})
                    return json_response(self, 200, payload)
                ok, msg = suite_stop_services(ports, include_portal=False)
                payload = suite_status_payload(ports)
                payload.update({"ok": ok, "message": msg})
                return json_response(self, 200, payload)
            if path == "/mssql/test":
                return json_response(self, 200, run_mssql("test", body))
            if path == "/mssql/write-current":
                rows = current_industrial_rows()
                if not rows:
                    return json_response(self, 200, {"ok": False, "error": "No current values. Configure and start replay first."})
                return json_response(self, 200, run_mssql("write", body, rows))
            if path == "/mssql/list-databases":
                return json_response(self, 200, run_mssql("list_databases", body))
            if path == "/mssql/list-tables":
                return json_response(self, 200, run_mssql("list_tables", body))
            if path == "/connections/save":
                write_store(CONNECTIONS_JSON, body)
                return json_response(self, 200, {"ok": True, "connections": body})
            if path == "/api-mappings/save":
                mappings = read_store(MAPPINGS_JSON, [])
                mappings = [m for m in mappings if m.get("endpoint_id") != body.get("endpoint_id")]
                mappings.append(body)
                write_store(MAPPINGS_JSON, mappings)
                return json_response(self, 200, {"ok": True, "mappings": mappings})
            return json_response(self, 404, {"ok": False, "error": "Not found"})
        except Exception as exc:
            return json_response(self, 500, {"ok": False, "error": str(exc)})


def main() -> None:
    print(f"Portal: http://127.0.0.1:{PORT}")
    print(f"Industrial simulator: http://127.0.0.1:{INDUSTRIAL_PORT}")
    print(f"API Studio: http://127.0.0.1:{API_STUDIO_PORT}")
    ThreadingHTTPServer(("0.0.0.0", PORT), Handler).serve_forever()


if __name__ == "__main__":
    main()
